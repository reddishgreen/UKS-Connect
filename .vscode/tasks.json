{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy Web Resource to D365",
      "type": "process",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/pacx/deploy-from-vscode.ps1",
        "-FullRelativePath", "${relativeFile}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
